{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "stream",
	"envMode": "loose",
	"globalDependencies": [
		"package.json",
		"bun.lock",
		"bunfig.toml",
		"biome.json",
		"tsconfig.json",
		"tsconfig.base.json",
		"tsconfig.tools.json",
		"packages/tsconfig.workspace.json"
	],
	"tasks": {
		"build": {
			"dependsOn": [
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!dist/**",
				"!.turbo/**",
				"!coverage/**",
				"!*.tsbuildinfo"
			],
			"outputs": [
				"dist/**",
				".next/**",
				"!.next/cache/**"
			]
		},
		"check": {
			"dependsOn": [
				"^check"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!dist/**",
				"!.turbo/**",
				"!coverage/**",
				"!*.tsbuildinfo"
			]
		},
		"check:types": {
			"dependsOn": [
				"^check:types"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!dist/**",
				"!.turbo/**",
				"!coverage/**",
				"!*.tsbuildinfo"
			]
		},
		"lint": {
			"inputs": [
				"$TURBO_DEFAULT$",
				"!dist/**",
				"!.turbo/**",
				"!coverage/**",
				"!*.tsbuildinfo"
			]
		},
		"test": {
			"dependsOn": [
				"check",
				"^check",
				"^build"
			],
			"inputs": [
				"$TURBO_DEFAULT$",
				"!dist/**",
				"!.turbo/**",
				"!coverage/**",
				"!*.tsbuildinfo"
			]
		},
		"fmt": {
			"cache": false
		},
		"fix": {
			"cache": false
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
